# services/agent — environment variables (copy to .env, never commit)
GOOGLE_CLOUD_PROJECT=spatial-cat-489006-a4
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_ENTERPRISE=true

# Agent Runtime resource name (set after provision.sh runs)
RO_ASSISTANT_AGENT_NAME=projects/spatial-cat-489006-a4/locations/global/agents/ro-assistant

# WaterTAP simulation endpoint
WATERTAP_API_URL=http://localhost:8000

# BigQuery dataset targets
BQ_CURATED_DATASET=ro_curated
BQ_SERVING_DATASET=ro_serving
BQ_EMBEDDINGS_DATASET=ro_embeddings
